<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0003-add-column-categorias-tipo" author="kevin">
        <addColumn tableName="categorias">
            <column name="tipo_categoria" type="VARCHAR(50)" defaultValue="DESPESA"/>
        </addColumn>

        <update tableName="categorias">
            <column name="tipo_categoria" value="DESPESA"/>
            <where>tipo_categoria IS NULL</where>
        </update>

        <addNotNullConstraint
                tableName="categorias"
                columnName="tipo_categoria"
                columnDataType="VARCHAR(50)"/>

        <dropDefaultValue
                tableName="categorias"
                columnName="tipo_categoria"
                columnDataType="VARCHAR(50)"/>

        <dropUniqueConstraint
                tableName="categorias"
                constraintName="uk_categorias_nome_user_classificacao"/>

        <dropNotNullConstraint
                tableName="categorias"
                columnName="classificacao"
                columnDataType="VARCHAR(50)"/>

        <sql dbms="postgresql">
            CREATE UNIQUE INDEX uk_categorias_receita_nome_user_tipo
            ON categorias (user_id, lower(nome), tipo_categoria)
            WHERE classificacao IS NULL;

            CREATE UNIQUE INDEX uk_categorias_despesa_nome_user_tipo_classificacao
            ON categorias (user_id, lower(nome), tipo_categoria, classificacao)
            WHERE classificacao IS NOT NULL;

            CREATE INDEX ix_categorias_nome_trgm ON categorias USING gin (lower(nome) gin_trgm_ops);
        </sql>
    </changeSet>
</databaseChangeLog>
