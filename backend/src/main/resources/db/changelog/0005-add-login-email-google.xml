<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0005-add-login-email-google" author="kevin">
        <dropIndex tableName="users" indexName="ix_users_cpf"/>
        <dropUniqueConstraint tableName="users" constraintName="uk_users_cpf"/>
        <dropColumn tableName="users" columnName="cpf"/>

        <dropNotNullConstraint tableName="users" columnName="senha" columnDataType="VARCHAR(255)"/>

        <addColumn tableName="users">
            <column name="google_subject" type="VARCHAR(255)"/>
        </addColumn>
        <addUniqueConstraint
                tableName="users"
                columnNames="google_subject"
                constraintName="uk_users_google_subject"/>
    </changeSet>
</databaseChangeLog>
