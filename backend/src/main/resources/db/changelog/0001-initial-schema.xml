<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- USERS -->
    <changeSet id="0001-01-create-users" author="copilot">
        <createTable tableName="users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_users" nullable="false"/>
            </column>
            <column name="nome" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="cpf" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>
            <column name="telefone" type="VARCHAR(50)"/>
            <column name="senha" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="roles" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="users" columnNames="email" constraintName="uk_users_email"/>
        <addUniqueConstraint tableName="users" columnNames="cpf" constraintName="uk_users_cpf"/>

        <createIndex tableName="users" indexName="ix_users_email">
            <column name="email"/>
        </createIndex>
        <createIndex tableName="users" indexName="ix_users_cpf">
            <column name="cpf"/>
        </createIndex>
    </changeSet>

    <!-- CATEGORIAS -->
    <changeSet id="0001-02-create-categorias" author="copilot">
        <createTable tableName="categorias">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_categorias" nullable="false"/>
            </column>
            <column name="descricao" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="classificacao" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="categorias" columnNames="descricao" constraintName="uk_categorias_descricao"/>
    </changeSet>

    <!-- PERIODOS_FINANCEIROS -->
    <changeSet id="0001-03-create-periodos-financeiros" author="copilot">
        <createTable tableName="periodos_financeiros">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_periodos_financeiros" nullable="false"/>
            </column>
            <column name="usuario_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="mes" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="ano" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="data_inicio" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="data_fim" type="DATE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="periodos_financeiros"
                baseColumnNames="usuario_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_periodos_usuario"
                onDelete="CASCADE"/>

        <createIndex tableName="periodos_financeiros" indexName="ix_periodos_usuario_id">
            <column name="usuario_id"/>
        </createIndex>
    </changeSet>

    <!-- PLANEJAMENTOS -->
    <changeSet id="0001-04-create-planejamentos" author="copilot">
        <createTable tableName="planejamentos">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_planejamentos" nullable="false"/>
            </column>
            <column name="periodo_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="categoria_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="valor_planejado" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="planejamentos"
                baseColumnNames="periodo_id"
                referencedTableName="periodos_financeiros"
                referencedColumnNames="id"
                constraintName="fk_planejamentos_periodo"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="planejamentos"
                baseColumnNames="categoria_id"
                referencedTableName="categorias"
                referencedColumnNames="id"
                constraintName="fk_planejamentos_categoria"/>

        <addUniqueConstraint tableName="planejamentos" columnNames="periodo_id, categoria_id" constraintName="uk_planejamentos_periodo_categoria"/>
    </changeSet>

    <!-- TRANSACOES_RECORRENTES -->
    <changeSet id="0001-05-create-transacoes-recorrentes" author="copilot">
        <createTable tableName="transacoes_recorrentes">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_transacoes_recorrentes" nullable="false"/>
            </column>
            <column name="usuario_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="categoria_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="descricao" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="valor" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_movimentacao" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_pagamento" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="frequencia" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="data_inicio" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="data_fim" type="DATE"/>
            <column name="total_parcelas" type="INTEGER"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="transacoes_recorrentes"
                baseColumnNames="usuario_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_transacoes_recorrentes_usuario"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="transacoes_recorrentes"
                baseColumnNames="categoria_id"
                referencedTableName="categorias"
                referencedColumnNames="id"
                constraintName="fk_transacoes_recorrentes_categoria"/>

        <createIndex tableName="transacoes_recorrentes" indexName="ix_transacoes_recorrentes_usuario_id">
            <column name="usuario_id"/>
        </createIndex>
    </changeSet>

    <!-- TRANSACOES -->
    <changeSet id="0001-06-create-transacoes" author="copilot">
        <createTable tableName="transacoes">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_transacoes" nullable="false"/>
            </column>
            <column name="usuario_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="categoria_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="periodo_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="transacao_recorrente_id" type="BIGINT"/>
            <column name="descricao" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="valor" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_movimentacao" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_pagamento" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="data" type="DATE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="transacoes"
                baseColumnNames="usuario_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_transacoes_usuario"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="transacoes"
                baseColumnNames="categoria_id"
                referencedTableName="categorias"
                referencedColumnNames="id"
                constraintName="fk_transacoes_categoria"/>

        <addForeignKeyConstraint
                baseTableName="transacoes"
                baseColumnNames="periodo_id"
                referencedTableName="periodos_financeiros"
                referencedColumnNames="id"
                constraintName="fk_transacoes_periodo"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="transacoes"
                baseColumnNames="transacao_recorrente_id"
                referencedTableName="transacoes_recorrentes"
                referencedColumnNames="id"
                constraintName="fk_transacoes_recorrente"/>

        <createIndex tableName="transacoes" indexName="ix_transacoes_usuario_id">
            <column name="usuario_id"/>
        </createIndex>
        <createIndex tableName="transacoes" indexName="ix_transacoes_periodo_id">
            <column name="periodo_id"/>
        </createIndex>
        <createIndex tableName="transacoes" indexName="ix_transacoes_recorrente_id">
            <column name="transacao_recorrente_id"/>
        </createIndex>

        <!-- Partial unique index for idempotent recurring generation -->
        <sql dbms="postgresql">
            CREATE UNIQUE INDEX ix_transacoes_recorrente_data_unique
            ON transacoes (transacao_recorrente_id, data)
            WHERE transacao_recorrente_id IS NOT NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
