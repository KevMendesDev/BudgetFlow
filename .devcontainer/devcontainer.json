{
  "name": "BudgetFlow DevContainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/BudgetFlow",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "remoteEnv": {
    "HTTP_PROXY": "${localEnv:http_proxy}",
    "HTTPS_PROXY": "${localEnv:https_proxy}",
    "NO_PROXY": "${localEnv:NO_PROXY}",
    "http_proxy": "${localEnv:http_proxy}",
    "https_proxy": "${localEnv:https_proxy}",
    "no_proxy": "${localEnv:no_proxy}",
    "MAVEN_OPTS": "--enable-native-access=ALL-UNNAMED"
  },
  "mounts": [
    "source=${localEnv:HOME}/.m2,target=/home/vscode/.m2,type=bind"
  ],
  "forwardPorts": [8080, 4200, 5432],
  "portsAttributes": {
    "8080": {
      "label": "BudgetFlow API (Spring Boot)",
      "onAutoForward": "notify"
    },
    "4200": {
      "label": "Angular Dev Server",
      "onAutoForward": "openPreview"
    },
    "5432": {
      "label": "PostgreSQL (Docker Compose)",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "redhat.java",
        "vmware.vscode-spring-boot",
        "ms-azuretools.vscode-docker",
        "Angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "interactive",
        "java.compile.nullAnalysis.mode": "automatic",
        "terminal.integrated.defaultProfile.linux": "bash",
        "java.configuration.maven.userSettings": "/home/vscode/.m2/settings.xml",
        "http.proxy": "${localEnv:http_proxy}",
        "http.proxySupport": "override",
        "http.systemCertificates": true,
        "http.proxyStrictSSL": false
      }
    }
  },
  "postCreateCommand": "bash -lc 'npm install -g @angular/cli@latest && npm install -g npm@11.11.1 && cd backend && ./mvnw -q -DskipTests dependency:go-offline || true'"
}
